<Window x:Class="Deploymentor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:System="clr-namespace:System;assembly=mscorlib" 
    mc:Ignorable="d"
    Title="Deploymentor" Height="600" Width="1350" WindowStartupLocation="CenterScreen"
    Style="{DynamicResource WindowStyle}"
    Tag="{Binding ElementName=tglDarkMode, Path=IsChecked, Mode=OneWay, FallbackValue=False}"
    x:Name="MainWindow"
    ContentRendered="Window_ContentRendered"
    >

    <Window.Resources>
        <!-- Global Dark Mode Window Style -->
        <Style x:Key="WindowStyle" TargetType="{x:Type Window}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=tglDarkMode, Path=IsChecked}" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="TextElement.Foreground" Value="#E0E0E0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Button -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A0A0A0" />
                </Trigger>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#333337" />
                    <Setter Property="Foreground" Value="#E0E0E0" />
                    <Setter Property="BorderBrush" Value="#555555" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#555555" />
                </MultiDataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button -->
        <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Content" Value="🌙 Dark Mode" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A0A0A0" />
                </Trigger>
                <DataTrigger Binding="{Binding ElementName=tglDarkMode, Path=IsChecked}" Value="True">
                    <Setter Property="Background" Value="#333337" />
                    <Setter Property="Foreground" Value="#E0E0E0" />
                    <Setter Property="BorderBrush" Value="#555555" />
                    <Setter Property="Content" Value="☀️ Light Mode" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#555555" />
                </MultiDataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CANCEL BUTTON EXCEPTION (Fixes dark mode bug where it turned gray) -->
        <Style x:Key="CancelButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <!-- This forces the button to stay red even in Dark Mode -->
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="Red" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC0000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Disabled Background -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#ABADB3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#333337"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="link" TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="Blue"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="#66B2FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox Full Template Override -->
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ABADB3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- The Box -->
                            <Border x:Name="checkBoxBorder" 
                                    Width="16" Height="16" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" 
                                    Margin="0,0,5,0" 
                                    CornerRadius="2">

                                <!-- The Checkmark -->
                                <Path x:Name="checkMark" 
                                      Data="M3,7 L6,10 L12,4" 
                                      Stroke="{TemplateBinding Foreground}" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round" 
                                      Visibility="Collapsed" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- The Text -->
                            <ContentPresenter Grid.Column="1" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Dark Mode Colors -->
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="Background" Value="#333337"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- COMBOBOX MAIN BOX & DROPDOWN ITEMS -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#ABADB3"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" Foreground="{TemplateBinding Foreground}" BorderBrush="{TemplateBinding BorderBrush}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#333337"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PROGRESS BAR -->
        <Style TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="#E6E6E6" />
            <Setter Property="Foreground" Value="#0078D7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderThickness="0"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#444444" />
                    <Setter Property="Foreground" Value="#0078D7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollBars -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Width="12" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" Focusable="false">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ScrollBar}}" RadiusX="6" RadiusY="6" Margin="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="Width" Value="Auto"/>
                                <Setter TargetName="GridRoot" Property="Height" Value="12"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="#555555"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ListView Disabled Background -->
        <Style TargetType="{x:Type ListView}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <!-- Fades out list rather than making it white -->
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBox Disabled Background -->
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBox}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Software List Items -->
        <Style x:Key="ListItemChackmarkStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Border" Background="Transparent" BorderThickness="5" BorderBrush="Transparent" Margin="0,0,0,4" Cursor="Hand">
                            <Grid>
                                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right" x:Name="Marker" Visibility="Hidden" Background="#0078D7" Padding="5,0,0,5" Foreground="White"><Run Text="✔"/></TextBlock>
                                <ContentPresenter />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Actions List Items -->
        <Style x:Key="ListItemChackmarkStyle2" TargetType="{x:Type ListViewItem}">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Grid x:Name="grid" Background="AliceBlue" Margin="0,0,0,4">
                            <Border x:Name="Border" Background="Transparent" BorderThickness="5" BorderBrush="Transparent" Cursor="Hand">
                                <Grid>
                                    <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right" x:Name="Marker" Visibility="Visible" Background="Transparent" Padding="5,0,0,5" Foreground="Silver"><Run Text="✔"/></TextBlock>
                                    <ContentPresenter />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="grid" Property="Background" Value="#2D2D30"/>
                                <Setter TargetName="Marker" Property="Foreground" Value="#666" />
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Marker" Property="Background" Value="#0078D7" />
                                <Setter TargetName="Marker" Property="Foreground" Value="White" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7"/>
                                <Setter TargetName="grid" Property="Background" Value="#0078D7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--- Tools List Box Items -->
        <Style x:Key="ListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#FF0078D7" />
        </Style>

        <!-- SCROLLVIEWER OVERRIDE (Fixes the white corner square) -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" 
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" 
                                                    Margin="{TemplateBinding Padding}" 
                                                    Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                       Grid.Column="1" Grid.Row="0"
                                       Maximum="{TemplateBinding ScrollableHeight}" 
                                       Minimum="0" 
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                       ViewportSize="{TemplateBinding ViewportHeight}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" 
                                       Grid.Column="0" Grid.Row="1"
                                       Maximum="{TemplateBinding ScrollableWidth}" 
                                       Minimum="0" 
                                       Orientation="Horizontal" 
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" 
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                       ViewportSize="{TemplateBinding ViewportWidth}"/>

                            <!-- THE FIX: A transparent rectangle so the window's dark background shows through -->
                            <Rectangle Grid.Column="1" Grid.Row="1" Fill="Transparent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GRID SPLITTER STYLE -->
        <Style TargetType="{x:Type GridSplitter}">
            <!-- Light Mode Color -->
            <Setter Property="Background" Value="#DDDDDD" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Style.Triggers>
                <!-- Dark Mode Color -->
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="#444444" />
                </DataTrigger>
                <!-- Hover Effect (Optional, gives user feedback it can be dragged) -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CONTEXT MENU STYLE -->
        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#ABADB3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="2">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Der Trick: Wir schauen auf das Tag des Elements, an dem das Menü hängt (ListView) -->
                <DataTrigger Binding="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- MENU ITEM STYLE -->
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20,5,20,5">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover-Farbe (Blau) -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0078D7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Dark Mode Schriftfarbe (holt sich den Status vom ContextMenu -> PlacementTarget) -->
                <DataTrigger Binding="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>



    <Grid>
        <Grid x:Name="tabControl" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel VerticalAlignment="Stretch" Orientation="Horizontal">
                    <TextBlock Text="Select a profile:" FontSize="14" Margin="10" VerticalAlignment="Center"/>
                    <ComboBox Margin="10" MinWidth="200" x:Name="cbProfileSelect" SelectionChanged="CbProfileSelect_SelectionChanged" VerticalAlignment="Center">
                        <TextBlock Text=""/>
                        <TextBlock Text="Profile 1"/>
                        <TextBlock Text="Profile 2"/>
                    </ComboBox>
                    <Button x:Name="doOpenConfig" Content="open config" VerticalAlignment="Center" Click="DoOpenConfig_Click" Margin="10" />
                    <CheckBox x:Name="cbActonsFirst" Checked="cbActonsFirst_Checked" Unchecked="cbActonsFirst_Checked" IsChecked="False" FontSize="14" VerticalAlignment="Center" Margin="10">Actions before Software</CheckBox>
                </StackPanel>

                <ToggleButton x:Name="tglDarkMode" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10" Padding="10,2" />
            </Grid>

            <Grid Grid.Row="1" VerticalAlignment="Stretch" x:Name="ContentPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="Frame">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- SOFTWARE SECTION -->
                    <Grid x:Name="software" Grid.Column="0" HorizontalAlignment="Stretch" Margin="10, 0, 10, 10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" FontSize="26" Content="Software"/>
                        <ListView Grid.Row="1" SelectionMode="Multiple" x:Name="lvSoftware" HorizontalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.CacheLengthUnit="Item" VirtualizingPanel.VirtualizationMode="Recycling" VerticalAlignment="Stretch" BorderBrush="Transparent" 
                        ItemContainerStyle="{StaticResource ListItemChackmarkStyle}" PreviewMouseRightButtonDown="lvSoftware_PreviewMouseRightButtonDown"
                        Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}">

                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="lvSoftware_ContextMenu" Header="Launch" Click="lvSoftware_ContextMenu_Click" />
                                </ContextMenu>
                            </ListView.ContextMenu>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="64" Margin="0,5" AutomationProperties.Name="{Binding Title}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0" Source="{Binding Icon}" Height="48" Width="48" VerticalAlignment="Center" Margin="5,0,20,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="16" TextWrapping="Wrap" Margin="0,0,22,0" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                            <ListViewItem IsSelected="True">
                                <Grid MinHeight="64" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Source="/default-app.png" Height="48" Width="48" VerticalAlignment="Center" Margin="8,8,17,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="Some TItle" FontSize="16" TextWrapping="Wrap" Margin="0,0,22,0" FontWeight="Bold"/>
                                        <TextBlock Text="Some Description" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </ListViewItem>
                        </ListView>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="10,10,10,10">
                            <Button x:Name="doInstall" Content="run" MinWidth="75" VerticalAlignment="Top" Click="DoInstallSoftware_Click" Margin="0,0,10,0" />
                            <Button x:Name="doSoftwareDir" Content="open dir" MinWidth="75" VerticalAlignment="Top" Click="DoSoftwareDir_Click" />
                        </StackPanel>

                        <ProgressBar Grid.Row="3" x:Name="pbSoftware" VerticalAlignment="Stretch" Minimum="0" Maximum="100" Value="50" Height="5" />
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

                    <!-- ACTIONS SECTION -->
                    <Grid x:Name="actions" Grid.Column="2" HorizontalAlignment="Stretch" Margin="10, 0, 10, 10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" FontSize="26" Content="Actions"/>
                        <ListView Grid.Row="1" SelectionMode="Multiple" x:Name="lvActions" BorderBrush="Transparent" VerticalAlignment="Stretch" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.CacheLengthUnit="Item" VirtualizingPanel.VirtualizationMode="Recycling" UseLayoutRounding="True" ItemContainerStyle="{StaticResource ListItemChackmarkStyle2}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5,5,25,5">
                                        <Grid VerticalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding Title}" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding Title2}" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="{Binding TextBoxVisibility2}" />

                                            <TextBox Grid.Column="1" Grid.Row="0" x:Name="tbValue" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="{Binding TextBoxVisibility}" Text="{Binding Value}" />
                                            <TextBox Grid.Column="1" Grid.Row="1" x:Name="tbValue2" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="{Binding TextBoxVisibility2}" Text="{Binding Value2}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Visibility="{Binding DescriptionVisibility}" Margin="0,5,0,0"  />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                            <ListViewItem IsSelected="True">
                                <StackPanel Margin="5,5,25,5">
                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Some Title&#x0a;row2" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="row2" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                        
                                        <TextBox Grid.Column="1" Grid.Row="0" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="Visible" Text="abcd" />
                                        <TextBox Grid.Column="1" Grid.Row="1" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="Visible" Text="efgh" />
                                    </Grid>
                                    <TextBlock Text="Some description .. use `n in PS as newline" TextWrapping="Wrap" FontSize="11" Visibility="Visible" Margin="0,5,0,0" />
                                </StackPanel>
                            </ListViewItem>

                            <ListViewItem>
                                <StackPanel Margin="5,5,25,5">
                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Some Title" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="row 2" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed" />
                                        <TextBox Grid.Column="1" Grid.Row="0" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="Visible" Text="abcd" />
                                        <TextBox Grid.Column="1" Grid.Row="1" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Visibility="Collapsed" Text="efgh" />
                                    </Grid>
                                    <TextBlock Text="Some description .. use `n in PS as newline" TextWrapping="Wrap" FontSize="11" Visibility="Visible" Margin="0,5,0,0"  />
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem>
                                <StackPanel Margin="5,5,25,5">
                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Some Title" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="row 2" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed" />
                                        <TextBox Grid.Column="1" Grid.Row="0" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}, Mode=FindAncestor}}" Visibility="Collapsed" Text="abcd" />
                                        <TextBox Grid.Column="1" Grid.Row="1" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}, Mode=FindAncestor}}" Visibility="Collapsed" Text="efgh" />
                                    </Grid>
                                    <TextBlock Text="Some description .. use `n in PS as newline" TextWrapping="Wrap" FontSize="11" Visibility="Visible" Margin="0,5,0,0"  />
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem>
                                <StackPanel Margin="5,5,25,5">
                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Some Title" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Visible" />
                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="row 2" LineHeight="auto" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed" />
                                        <TextBox Grid.Column="1" Grid.Row="0" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}, Mode=FindAncestor}}" Visibility="Collapsed" Text="abcd" />
                                        <TextBox Grid.Column="1" Grid.Row="1" Margin="20,0,0,2" IsEnabled="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}, Mode=FindAncestor}}" Visibility="Collapsed" Text="efgh" />
                                    </Grid>
                                    <TextBlock Text="Some description .. use `n in PS as newline" TextWrapping="Wrap" FontSize="11" Visibility="Collapsed" Margin="0,5,0,0"  />
                                </StackPanel>
                            </ListViewItem>
                            

                        </ListView>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="10,10,10,10">
                            <Button x:Name="doActions" Content="run" MinWidth="75" VerticalAlignment="Top" Click="DoInstallActions_Click" Margin="0,0,10,0" />
                            <Button x:Name="doActionsDir" Content="open dir" MinWidth="75" VerticalAlignment="Top" Click="DoActionsDir_Click" />
                        </StackPanel>
                        <ProgressBar Grid.Row="3" x:Name="pbActions" VerticalAlignment="Stretch" Minimum="0" Maximum="100" Value="75" Height="5" />
                    </Grid>

                    <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" />

                    <!-- TOOLS / CONFIG SECTION -->
                    <Grid x:Name="tools" Grid.Column="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="10, 0, 10, 10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" FontSize="26" Content="Tools / Config"/>
                        <ListBox Grid.Row="1" x:Name="lvTools" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.CacheLengthUnit="Item" VirtualizingPanel.VirtualizationMode="Recycling" BorderBrush="Transparent" SelectionChanged="LvTools_SelectionChanged" ItemContainerStyle="{StaticResource ListBoxItemStyle}" >
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBox}}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="100" Width="100" Padding="5" Background="#E50078D7">
                                        <Grid>
                                            <Image Source="{Binding Icon, FallbackValue=/default-app.png}" Height="40" Margin="0,-15,0,5" />
                                            <TextBlock TextWrapping="Wrap" Text="{Binding Title, FallbackValue=Tool}" VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBoxItem>
                                <Border Height="100" Width="100" Padding="5" Background="#E50078D7">
                                    <Grid>
                                        <Image Source="/default-app.png" Height="40" Margin="0,-15,0,5" />
                                        <TextBlock TextWrapping="Wrap" Text="Some Tool" VerticalAlignment="Bottom" />
                                    </Grid>
                                </Border>
                            </ListBoxItem>
                        </ListBox>
                    </Grid>
                </Grid>

                <Grid x:Name="ButtonBar" Grid.Row="1" Height="30" VerticalAlignment="Bottom" Margin="10,10,10,10">
                    <Label x:Name="lbCopy" HorizontalAlignment="Right" MouseDown="LbCopy_MouseDown" Style="{StaticResource link}" Cursor="Hand">© Nabil Redmann 2026</Label>
                    <Button x:Name="doInstallAll" Content="run all" Width="75" VerticalAlignment="Center" Click="DoInstallAll_Click" />
                </Grid>
            </Grid>
        </Grid>

        <!-- CANCEL OVERLAY -->
        <Grid VerticalAlignment="Center" x:Name="overlayCancel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="#E50078D7" Grid.ColumnSpan="3" />
            <StackPanel Margin="0,25,0,25" Grid.Column="1">
                <Label FontSize="26" Foreground="White" Content="Processing ..."/>
                <Button x:Name="btnCancel" Style="{StaticResource CancelButtonStyle}" HorizontalAlignment="Center" Margin="0,15,0,0" Padding="20,0" Height="50" Click="BtnCancel_Click" FontSize="20" FontWeight="Bold" Content="Cancel" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>